{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit|Read|WebFetch|WebSearch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/run.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v python3 >/dev/null 2>&1 || printf 'certior-guard: python3 not found on PATH — the guard hook fails open (allows everything). Install Python 3.11+ to enable protection.\\n' >&2",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
